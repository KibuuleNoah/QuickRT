// ─── Campaign Card ─────────────────────────────────────────────────────────────

function CampaignCard({ c, i }: { c: Campaign; i: number }) {
  const pct = Math.round((c.scratched / c.total) * 100);
  return (
    <motion.div className="campaign-card" {...stagger(i)}>
      <div className="cc-top">
        <div
          className="cc-logo"
          style={{
            background: `${c.color}22`,
            border: `1px solid ${c.color}44`,
          }}
        >
          {c.brandLogo}
        </div>
        <div className="cc-info">
          <p className="cc-brand">{c.brand}</p>
          <p className="cc-name">{c.name}</p>
        </div>
        <TooltipProvider>
          <Tooltip>
            <TooltipTrigger asChild>
              <span className="cc-ends">⏱ {c.endsIn}</span>
            </TooltipTrigger>
            <TooltipContent side="top">
              <p>Campaign ends in {c.endsIn}</p>
            </TooltipContent>
          </Tooltip>
        </TooltipProvider>
      </div>
      <div className="cc-progress-track">
        <motion.div
          className="cc-progress-fill"
          style={{ background: c.color }}
          initial={{ width: 0 }}
          animate={{ width: `${pct}%` }}
          transition={{ duration: 0.9, ease: "easeOut", delay: i * 0.1 + 0.2 }}
        />
      </div>
      <div className="cc-bottom">
        <span className="cc-stat">
          {c.scratched}/{c.total} scratched
        </span>
        <span className="cc-prize">{c.totalPrize} pool</span>
      </div>
    </motion.div>
  );
}

// ─── Reward Card ──────────────────────────────────────────────────────────────

function RewardCard({ r, i }: { r: Reward; i: number }) {
  const isAvail = r.status === "available";
  const isExp = r.status === "expired";
  return (
    <motion.div className={`reward-card ${r.status}`} {...stagger(i)}>
      <div className="rc-left">
        <div className="rc-icon">{isAvail ? "💰" : isExp ? "💸" : "✅"}</div>
        <div>
          <p className="rc-title">{r.title}</p>
          <p className="rc-brand">{r.brand}</p>
        </div>
      </div>
      <div className="rc-right">
        <p
          className="rc-amount"
          style={{ color: isAvail ? "#16C784" : "#6B7280" }}
        >
          {fmtAmount(r.amount, r.currency)}
        </p>
        {isAvail && <p className="rc-exp">Expires in {r.expiresIn}</p>}
        {r.status === "redeemed" && (
          <p className="rc-exp">Redeemed {r.redeemedOn}</p>
        )}
        {isAvail && (
          <motion.button
            className="rc-btn"
            whileTap={{ scale: 0.97 }}
            whileHover={{ scale: 1.03 }}
          >
            Redeem
          </motion.button>
        )}
      </div>
    </motion.div>
  );
}

// ─── Sidebar Nav ──────────────────────────────────────────────────────────────

const NAV: { key: NavItem; icon: string; label: string }[] = [
  { key: "overview", icon: "◈", label: "Overview" },
  { key: "history", icon: "📋", label: "Scratch History" },
