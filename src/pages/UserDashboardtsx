// ─── Helpers ──────────────────────────────────────────────────────────────────

const fmtAmount = (n: number, cur: string) => `${cur} ${n.toLocaleString()}`;

const statusColor: Record<ScratchStatus, string> = {
  won: "#16C784",
  lost: "#EF4444",
  pending: "#FBBF24",
};
const statusLabel: Record<ScratchStatus, string> = {
  won: "Won",
  lost: "No Win",
  pending: "Pending",
};

function stagger(i: number) {
  return {
    initial: { opacity: 0, y: 16 },
    animate: { opacity: 1, y: 0 },
    transition: { delay: i * 0.06, duration: 0.35, ease: [0.4, 0, 0.2, 1] },
  };
}

// ─── Stat Card ────────────────────────────────────────────────────────────────

function StatCard({
  label,
  value,
  sub,
  icon,
  accent,
  i,
}: {
  label: string;
  value: string;
  sub: string;
  icon: string;
  accent: string;
  i: number;
}) {
  return (
    <motion.div
      className="stat-card"
      {...stagger(i)}
      style={{ "--accent": accent } as React.CSSProperties}
    >
      <div className="stat-icon">{icon}</div>
      <div className="stat-body">
        <p className="stat-label">{label}</p>
        <p className="stat-value">{value}</p>
        <p className="stat-sub">{sub}</p>
      </div>
      <div className="stat-glow" />
    </motion.div>
  );
}

// ─── Activity Ring ─────────────────────────────────────────────────────────────

function WinRing({ rate }: { rate: number }) {
  const r = 44;
  const circ = 2 * Math.PI * r;
  const dash = (rate / 100) * circ;
  return (
    <svg width="110" height="110" viewBox="0 0 110 110">
      <circle
        cx="55"
        cy="55"
        r={r}
        fill="none"
        stroke="#1F2937"
        strokeWidth="10"
      />
      <motion.circle
        cx="55"
        cy="55"
        r={r}
        fill="none"
        stroke="#16C784"
        strokeWidth="10"
        strokeLinecap="round"
        strokeDasharray={circ}
        initial={{ strokeDashoffset: circ }}
        animate={{ strokeDashoffset: circ - dash }}
        transition={{ duration: 1.2, ease: "easeOut", delay: 0.3 }}
        style={{ rotate: "-90deg", transformOrigin: "55px 55px" }}
      />
      <text
        x="55"
        y="50"
        textAnchor="middle"
        fill="#F9FAFB"
        fontSize="18"
        fontWeight="700"
        fontFamily="Syne, sans-serif"
      >
        {rate}%
      </text>
      <text
        x="55"
        y="66"
        textAnchor="middle"
        fill="#6B7280"
        fontSize="10"
        fontFamily="DM Sans, sans-serif"
      >
        Win Rate
      </text>
    </svg>
  );
}

