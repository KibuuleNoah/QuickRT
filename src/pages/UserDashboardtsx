function Sidebar({
  active,
  setActive,
  collapsed,
  setCollapsed,
}: {
  active: NavItem;
  setActive: (n: NavItem) => void;
  collapsed: boolean;
  setCollapsed: (v: boolean) => void;
}) {
  return (
    <motion.aside
      className="sidebar"
      animate={{ width: collapsed ? 68 : 220 }}
      transition={{ type: "spring", stiffness: 300, damping: 30 }}
    >
      {/* Logo */}
      <div className="sb-logo">
        <span className="sb-logo-icon">◈</span>
        <AnimatePresence>
          {!collapsed && (
            <motion.span
              className="sb-logo-text"
              initial={{ opacity: 0, x: -8 }}
              animate={{ opacity: 1, x: 0 }}
              exit={{ opacity: 0, x: -8 }}
              transition={{ duration: 0.2 }}
            >
              WinHub
            </motion.span>
          )}
        </AnimatePresence>
      </div>

      {/* Nav */}
      <nav className="sb-nav">
        {NAV.map((item) => (
          <TooltipProvider
            key={item.key}
            delayDuration={collapsed ? 100 : 9999}
          >
            <Tooltip>
              <TooltipTrigger asChild>
                <button
                  className={`sb-item ${active === item.key ? "active" : ""}`}
                  onClick={() => setActive(item.key)}
                >
                  <span className="sb-item-icon">{item.icon}</span>
                  <AnimatePresence>
                    {!collapsed && (
                      <motion.span
                        className="sb-item-label"
                        initial={{ opacity: 0, x: -6 }}
                        animate={{ opacity: 1, x: 0 }}
                        exit={{ opacity: 0, x: -6 }}
                        transition={{ duration: 0.18 }}
                      >
                        {item.label}
                      </motion.span>
                    )}
                  </AnimatePresence>
                  {active === item.key && (
                    <motion.div className="sb-active-pill" layoutId="sb-pill" />
                  )}
                </button>
              </TooltipTrigger>
              {collapsed && (
                <TooltipContent side="right">
                  <p>{item.label}</p>
                </TooltipContent>
              )}
            </Tooltip>
          </TooltipProvider>
        ))}
      </nav>

      {/* Collapse toggle */}
      <button
        className="sb-collapse-btn"
        onClick={() => setCollapsed(!collapsed)}
      >
        <span
          style={{
            transform: collapsed ? "rotate(180deg)" : "rotate(0deg)",
            display: "inline-block",
            transition: "transform 0.3s",
          }}
        >
          ‹
        </span>
      </button>
    </motion.aside>
  );
}

